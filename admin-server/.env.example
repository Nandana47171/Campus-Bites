# Admin server example env
# Set a secure admin username and password in production
ADMIN_USERNAME=adminuser
ADMIN_PASSWORD=YourStrongPassword!
ADMIN_EMAIL=admin@example.com
PORT=4000

# Optional rate limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=900000

# Optional IP allowlist (comma-separated). Leave empty to allow all.
# IP_ALLOWLIST=203.0.113.5,198.51.100.22

# To explicitly allow defaults (not recommended), set:
# ALLOW_DEFAULT_ADMIN=true
